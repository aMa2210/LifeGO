# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ── Prisma / SQLite (recursive — Prisma sometimes creates nested prisma/ paths) ──
**/*.db
**/*.db-journal

# ── Mobile (Expo) artifacts ──
mobile/node_modules
mobile/.expo
mobile/.expo-shared
mobile/dist
mobile/web-build
mobile/ios
mobile/android
mobile/*.jks
mobile/*.p8
mobile/*.p12
mobile/*.key
mobile/*.mobileprovision

# Auto-generated expo router types
mobile/.expo/types
mobile/expo-env.d.ts

# ── Dev session transient logs ──
*.log
.expo-init.log
.expo-deps.log
.expo-peers.log
.npm-install*.log
mobile/.expo-dev.log
