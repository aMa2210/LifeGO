{
  "expo": {
    "name": "LifeGO",
    "slug": "lifego",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lifego",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.lifego.app",
      "icon": "./assets/expo.icon",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "LifeGO uses your location to suggest places near you and to log check-ins.",
        "NSPhotoLibraryUsageDescription": "LifeGO needs photo library access so you can attach a photo to a check-in."
      }
    },
    "android": {
      "package": "com.lifego.app",
      "adaptiveIcon": {
        "backgroundColor": "#fef3c7",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#fef3c7",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "@rnmapbox/maps"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "983040c3-0c05-4292-813c-52049a28921a"
      }
    },
    "owner": "makemoneyama"
  }
}
